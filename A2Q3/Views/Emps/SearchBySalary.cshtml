@model IEnumerable<A2Q3.Models.Emp>

@{
    ViewBag.Title = "Search Employees By Salary";
}

<h2>Search Employees With Salary Greater Than Input</h2>

@using (Html.BeginForm())
{
    <div class="form-group">
        <label>Enter Minimum Salary</label>
        <input type="number" name="salary" class="form-control" step="0.01" required />
    </div>

    <button type="submit" class="btn btn-primary">Search</button>
}

@if (ViewBag.Message != null)
{
    <div class="alert alert-warning mt-2">@ViewBag.Message</div>
}

@if (Model != null && Model.Any())
{
    <h3>Search Results</h3>

    <table class="table table-bordered table-striped">
        <tr>
            <th>Emp No</th>
            <th>Name</th>
            <th>Salary</th>
            <th>Department</th>
            <th>Designation</th>
        </tr>

        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.EmpNo</td>
                <td>@emp.name</td>
                <td>@emp.salary</td>
                <td>@emp.dept1.dept_name</td>
                <td>@emp.desg.desg_name</td>
            </tr>
        }
    </table>
}
