
@model A2Q3.Models.IncrementViewModel

@{
    ViewBag.Title = "Increment Salary";
}

<h2>Increment Salary by Department</h2>

@using (Html.BeginForm())
{
    <div class="form-group">
        @Html.Label("Department")
        @Html.DropDownListFor(m => m.Dept_id, (SelectList)ViewBag.DeptList, "Select Department", new { @class = "form-control" })

    </div>

    <div class="form-group">
        @Html.Label("Increment Percentage")
        @Html.TextBoxFor(m => m.IncrementPercent, new { @class = "form-control", type = "number", step = "0.01" })
    </div>

    <button type="submit" class="btn btn-primary">Apply Increment</button>
}

@if (ViewBag.Message != null)
{
    <div class="alert alert-info">
        @ViewBag.Message
    </div>
}
